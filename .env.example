# Environment Variables for Iconsultant Pro
# Copy this file to .env.local and fill in the values

# ======================
# DATABASE (Neon PostgreSQL)
# ======================
# Get these from https://neon.tech dashboard
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ======================
# AUTH (NextAuth.js)
# ======================
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-super-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ======================
# EMAIL (Resend)
# ======================
# Get from https://resend.com
RESEND_API_KEY="re_your_api_key_here"
EMAIL_FROM="noreply@yourdomain.com"

# ======================
# AI (Anthropic Claude)
# ======================
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-your_api_key_here"

# ======================
# AI (OpenAI Whisper)
# ======================
# Usado para transcrição de áudio em reuniões (opcional — Web Speech API é o fallback)
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# ======================
# APP CONFIG
# ======================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Iconsultant Pro"

# ======================
# AI (Vexa Meeting Bot)
# ======================
VEXA_API_KEY="vx_sk_your_api_key_here"
VEXA_API_URL="https://api.cloud.vexa.ai"

